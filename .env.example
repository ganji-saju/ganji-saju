# Site (NEXT_PUBLIC_* values are exposed to the browser)
# Phase 1 (2026-05-18): canonical 도메인 = https://ganjisaju.kr (영문 ASCII).
# 한글/punycode/www 등은 src/proxy.ts 에서 production 환경에서만 308 redirect.
NEXT_PUBLIC_SITE_URL=https://ganjisaju.kr

# Supabase (service role stays server-only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Toss Payments (client key is public, secret key is server-only)
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_your-toss-client-key
TOSS_SECRET_KEY=test_sk_your-toss-secret-key

# OpenAI / AI interpretation (server-only)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5.2
OPENAI_INTERPRET_MODEL=gpt-5.2-chat-latest

# Public data validation (server-only, optional local validation script)
KASI_SERVICE_KEY=your-data-go-kr-service-key

# Birth location lookup (server-only, optional)
BIRTH_LOCATION_GEOCODER_URL=https://nominatim.openstreetmap.org/search
BIRTH_LOCATION_GEOCODER_USER_AGENT=saju-app/1.0 (+https://your-domain.com)

# Web Push / Notifications (public key is browser-exposed, private key stays server-only)
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=your-web-push-public-key
WEB_PUSH_PRIVATE_KEY=your-web-push-private-key
WEB_PUSH_SUBJECT=mailto:notifications@your-domain.com

# Vercel Cron uses CRON_SECRET. Manual notification calls may use NOTIFICATION_CRON_SECRET.
CRON_SECRET=replace-with-a-long-random-string
NOTIFICATION_CRON_SECRET=replace-with-a-long-random-string

# PR #141 — admin 화이트리스트 (comma-separated user UUID). 부트스트랩용.
# DB admin_users 테이블에 row 가 있으면 그쪽도 통과 — 둘 다 OR 관계.
ADMIN_USER_IDS=

# ─────────────────────────────────────────────────────────────────────────────
# 사업자 정보 — Phase 3-A (2026-05-18). 모두 NEXT_PUBLIC_ (클라이언트 노출, 비밀 아님).
# production 빌드 시 src/lib/business-info.ts 의 가드가 누락값 검출 → throw.
# 운영자: Vercel 대시보드 → Settings → Environment Variables 에 실제 값 입력.
# 상세: docs/legal-required-fields.md §3.
# ─────────────────────────────────────────────────────────────────────────────

# 사업자 기본 (전자상거래법 §13 의무 표기)
NEXT_PUBLIC_COMPANY_NAME=
NEXT_PUBLIC_CEO_NAME=
NEXT_PUBLIC_BUSINESS_REGISTRATION_NUMBER=
NEXT_PUBLIC_MAIL_ORDER_REGISTRATION_NUMBER=
NEXT_PUBLIC_BUSINESS_ADDRESS=
# 선택: 사업자정보 공시 URL (예: https://www.ftc.go.kr/bizCommPop.do?wrkr_no=XXXXXXXXXXX)
NEXT_PUBLIC_BUSINESS_INFO_VERIFICATION_URL=

# 고객센터
NEXT_PUBLIC_CS_PHONE=
NEXT_PUBLIC_CS_EMAIL=
NEXT_PUBLIC_CS_HOURS=

# 개인정보보호책임자 (개인정보보호법 §31 의무 표기)
NEXT_PUBLIC_PRIVACY_OFFICER_NAME=
NEXT_PUBLIC_PRIVACY_OFFICER_EMAIL=
# 선택: CPO 전용 전화. 비어 있으면 CS 전화 fallback.
NEXT_PUBLIC_PRIVACY_OFFICER_PHONE=
