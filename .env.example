# Site (NEXT_PUBLIC_* values are exposed to the browser)
# Phase 1 (2026-05-18): canonical 도메인 = https://ganjisaju.kr (영문 ASCII).
# 한글/punycode/www 등은 src/proxy.ts 에서 production 환경에서만 308 redirect.
NEXT_PUBLIC_SITE_URL=https://ganjisaju.kr

# Supabase (service role stays server-only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Toss Payments (client key is public, secret key is server-only)
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_your-toss-client-key
TOSS_SECRET_KEY=test_sk_your-toss-secret-key

# OpenAI / AI interpretation (server-only)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5.2
OPENAI_INTERPRET_MODEL=gpt-5.2-chat-latest
# V2-5 챕터별 LLM enhancement — '1' 활성 + 챕터 ID 콤마/범위 (예: '1-9' or '1,4,5').
# 현재 구현된 챕터:
#   1 (타고난 성향) / 2 (기운의 균형) / 3 (역할과 보완) / 4 (관계 패턴) /
#   5 (재물 감각) / 6 (직업 방향) / 7 (건강 리듬) / 9 (평생 활용 전략 synthesis).
# 챕터 8 (대운) 은 daewoon-llm-spec.md 별도 위임 — 본 flag 와 무관.
# 미설정 또는 '0' 이면 deterministic builder 본문 그대로 (회귀 0).
# 호출 패턴: 1~7 *병렬* (Promise.all) → 9 *직렬* (priorChapterDigests 필요).
OPENAI_INTERPRET_CHAPTERS=0
OPENAI_INTERPRET_CHAPTER_IDS=1-9

# 사주 총평(결과 페이지 총평 탭) LLM 풀이 — saju-total-review-llm-spec.md.
# '1' 이면 한 줄 요약 + 본문 4단락 + 평생 활용 3카드를 LLM 생성.
# 미설정 또는 '0' 이면 deterministic buildSajuNarrative 본문 그대로 (회귀 0).
# 호출 패턴: 3섹션 *병렬* (Promise.all). hard 위반(한자/명리어/일일톤) 시 자동 fallback.
OPENAI_INTERPRET_TOTAL_REVIEW=0

# 궁합(compatibility) 깊은 풀이 LLM — PR #345. '1' 이면 두 사람 맞춤 깊은 풀이를 LLM 생성.
# 미설정 또는 '0' 이면 deterministic deepSections 본문 그대로(회귀 0). hard 위반 시 자동 fallback.
# 2026-05-24: 프로덕션 Vercel env 에 1 로 설정됨(활성).
OPENAI_INTERPRET_COMPATIBILITY=0

# Public data validation (server-only, optional local validation script)
KASI_SERVICE_KEY=your-data-go-kr-service-key

# Birth location lookup (server-only, optional)
BIRTH_LOCATION_GEOCODER_URL=https://nominatim.openstreetmap.org/search
BIRTH_LOCATION_GEOCODER_USER_AGENT=saju-app/1.0 (+https://your-domain.com)

# Web Push / Notifications (public key is browser-exposed, private key stays server-only)
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=your-web-push-public-key
WEB_PUSH_PRIVATE_KEY=your-web-push-private-key
WEB_PUSH_SUBJECT=mailto:notifications@your-domain.com

# Vercel Cron uses CRON_SECRET. Manual notification calls may use NOTIFICATION_CRON_SECRET.
CRON_SECRET=replace-with-a-long-random-string
NOTIFICATION_CRON_SECRET=replace-with-a-long-random-string

# PR #141 — admin 화이트리스트 (comma-separated user UUID). 부트스트랩용.
# DB admin_users 테이블에 row 가 있으면 그쪽도 통과 — 둘 다 OR 관계.
ADMIN_USER_IDS=

# ─────────────────────────────────────────────────────────────────────────────
# 사업자 정보 — Phase 3-A (2026-05-18). 모두 NEXT_PUBLIC_ (클라이언트 노출, 비밀 아님).
# production 빌드 시 src/lib/business-info.ts 의 가드가 누락값 검출 → throw.
# 운영자: Vercel 대시보드 → Settings → Environment Variables 에 실제 값 입력.
# 상세: docs/legal-required-fields.md §3.
# ─────────────────────────────────────────────────────────────────────────────

# 사업자 기본 (전자상거래법 §13 의무 표기)
# 2026-05-18: 실제값. NEXT_PUBLIC_* = 공개 정보 (푸터/정책 페이지 노출).
# 운영자는 Vercel 대시보드 Production env 에 동일 값을 직접 입력해야 함 (production 가드 통과).
NEXT_PUBLIC_COMPANY_NAME=푸꼬컴퍼니
NEXT_PUBLIC_CEO_NAME=김재호
NEXT_PUBLIC_BUSINESS_REGISTRATION_NUMBER=215-27-64715
NEXT_PUBLIC_MAIL_ORDER_REGISTRATION_NUMBER=제 2025-서울중랑-1862 호
NEXT_PUBLIC_BUSINESS_ADDRESS=서울특별시 중랑구 동일로 909, 3층 301호 일부호(묵동)
NEXT_PUBLIC_BUSINESS_INFO_VERIFICATION_URL=https://www.ftc.go.kr/bizCommPop.do?wrkr_no=2152764715

# 고객센터
NEXT_PUBLIC_CS_PHONE=010-8123-9184
NEXT_PUBLIC_CS_EMAIL=ganjisaju12@gmail.com
NEXT_PUBLIC_CS_HOURS=평일 10:00-19:00 / 점심 13:00-14:00 제외

# 개인정보보호책임자 (개인정보보호법 §31 의무 표기)
NEXT_PUBLIC_PRIVACY_OFFICER_NAME=김재호
NEXT_PUBLIC_PRIVACY_OFFICER_EMAIL=ganjisaju@gmail.com
NEXT_PUBLIC_PRIVACY_OFFICER_PHONE=010-8123-9184

# 2026-05-18 Phase 7b — 후기(reviews) userId 공개 hash 의 salt.
# 32 bytes hex 권장. 미설정 시 default salt 사용 (보안 영향 미미하나 production 권장).
# 생성 예: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REVIEW_USER_HASH_SALT=
