# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
# .next 백업/캐시 변형 (빌드 중 캐시 손상 회피용으로 mv 한 디렉터리들 — 추적 금지)
/.next.*
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.tmp-*.log
.codex-run/

# env files (never commit secrets; keep only the template)
.env
.env.*
!.env.example

# vercel
.vercel

# supabase cli
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# playwright e2e
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
e2e/.auth/
# playwright MCP 도구 캐시 (커밋 금지)
/.playwright-mcp/

# superpowers SDD 스크래치 (진행 원장·태스크 브리프·리뷰 패키지 — 로컬 전용)
/.superpowers/

# generated progress report (PROGRESS.md → HTML via scripts/render-progress.mjs)
PROGRESS.html

# claude code local settings (personal, not committed)
.claude/settings.local.json

# direnv — 레포별 gh/vercel/supabase 계정 고정용 .envrc (토큰 동적 추출, 커밋 금지)
.envrc
.direnv/

# 가독성 회귀 스크린샷(사람 검토용 산출물, 재생성 가능)
e2e/readability-shots/
